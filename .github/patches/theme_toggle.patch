+
+// ============================================================
+// THEME TOGGLE
+// ============================================================
+function setTheme(pref) {
+  localStorage.setItem('fleetflow-theme', pref);
+  window._ffThemePref = pref;
+  var effective = pref;
+  if (pref === 'system') {
+    effective = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
+  }
+  document.documentElement.setAttribute('data-theme', effective);
+  _updateThemeBtns(pref);
+}
+
+function _updateThemeBtns(pref) {
+  ['dark','light','system'].forEach(function(t) {
+    var btn = document.getElementById('theme-btn-' + t);
+    if (btn) btn.classList.toggle('active', t === pref);
+  });
+}
+
+// Apply active state once DOM is ready
+(function() {
+  var pref = window._ffThemePref || localStorage.getItem('fleetflow-theme') || 'dark';
+  // Wait for DOM ready
+  if (document.readyState === 'loading') {
+    document.addEventListener('DOMContentLoaded', function() { _updateThemeBtns(pref); });
+  } else {
+    _updateThemeBtns(pref);
+  }
+  // Listen for system preference changes when in 'system' mode
+  window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function(e) {
+    if (window._ffThemePref === 'system') {
+      document.documentElement.setAttribute('data-theme', e.matches ? 'light' : 'dark');
+    }
+  });
+})();
 </script>
