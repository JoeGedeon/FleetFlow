   :root {
-    --navy: #0a1628;
+    /* Semantic theme tokens */
+    --bg-primary:    #f0f4f8;
+    --bg-secondary:  #dce6f0;
+    --bg-surface:    #e4edf6;
+    --text-primary:  #0d1f3c;
+    --text-secondary:#3a5070;
+    --border-color:  #b0c4d8;
+    --accent-color:  #008822;
+    --input-bg:      #f8fbff;
+    --card-bg:       #e8f0f8;
+    --modal-bg:      #dce6f0;
+
+    /* Alias existing vars to tokens so all downstream CSS still works */
+    --navy:  var(--bg-primary);
+    --navy2: var(--bg-secondary);
+    --navy3: var(--bg-surface);
