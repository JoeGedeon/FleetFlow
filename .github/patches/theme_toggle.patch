 <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
+<!-- Theme restore — runs before body renders to prevent flash -->
+<script>
+(function(){
+  var saved = localStorage.getItem('fleetflow-theme') || 'dark';
+  var effective = saved;
+  if (saved === 'system') {
+    effective = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
+  }
+  document.documentElement.setAttribute('data-theme', effective);
+  // Store resolved for system preference listener
+  window._ffThemePref = saved;
+})();
+</script>
